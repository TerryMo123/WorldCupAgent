# 世界杯球队对比 Agent

# 超时（秒）
REQUEST_TIMEOUT=10
TOOL_TIMEOUT=2.5

# LLM 并发上限
LLM_MAX_CONCURRENCY=50

# 背压
QUEUE_MAXSIZE=200
QUEUE_PUT_TIMEOUT=2

# Mock 延迟（测试 / 压测用；生产切 chroma + qwen 后可忽略）
MOCK_STATS_DELAY=0.05
MOCK_RAG_DELAY=0.1
MOCK_LLM_DELAY=0.8
MOCK_FAILURE_RATE=0

DEBUG=false

# 后端：mock（默认，pytest 无需 API Key）| chroma + qwen（生产）
RAG_BACKEND=mock
LLM_BACKEND=mock

# 百炼通义 DashScope（OpenAI 兼容模式，同一 Key 用于 Embedding + LLM）
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v4
# LLM_MODEL=qwen-plus
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.3

# 生产示例：
# RAG_BACKEND=chroma
# LLM_BACKEND=qwen
# DASHSCOPE_API_KEY=sk-...
# 然后运行: python scripts/ingest_embeddings.py --force

# Chroma 向量库路径
# CHROMA_PERSIST_DIR=data/chroma
# CHROMA_COLLECTION=worldcup_teams

# 赛况快照 SQLite（P1 数据管道）
# TOURNAMENT_DB_PATH=data/tournament.db
# TOURNAMENT_SNAPSHOT_DIR=data/snapshots
# TOURNAMENT_YEAR=2026

# 赔率（P2）：mock（默认，无需 API Key）| the_odds_api
# ODDS_BACKEND=mock
# ODDS_API_KEY=
# ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
# ODDS_SPORT_KEY=soccer_fifa_world_cup
# ODDS_REGIONS=us
# ODDS_MARKETS=h2h
# 抓取: python scripts/fetch_odds.py  或  python scripts/pipeline.py --fetch-odds --odds-mock

# 路径（一般不用改）
# DATA_DIR=data
# DOCS_DIR=docs/teams
# DB_PATH=data/worldcup.db
# SKILL_PATH=skills/worldcup-compare/SKILL.md
